#!/bin/bash

# GE-Proton update script for Linux desktops
# Installs latest GE-Proton to Steam's compatibilitytools.d directory
#
# Usage Notes:
# - Ideal as a post-hook for apt-up or pac-up (e.g., /etc/apt-up.d/post.d/50-ge-proton or /etc/pac-up.d/post.d/50-ge-proton)
# - Set GE_PROTON_TARGET to override the install directory:
#   - In-script: GE_PROTON_TARGET="/custom/path" (uncomment below)
#   - Export: export GE_PROTON_TARGET="/home/user/.steam/steam/compatibilitytools.d"
#   - CLI: GE_PROTON_TARGET="/path" ./50-ge-proton
# - Set GE_PROTON_ARCH to force a specific build (x86_64 or aarch64) regardless
#   of the detected CPU — useful under a translation layer (FEX-Emu, box64,
#   qemu-user, etc.) or to stage a build for another machine. Auto-detected if
#   unset; an unrecognized CPU falls back to x86_64 with a warning.
# - Use --force-root to allow installation to /root/.steam/... as root
# - Use --debug for verbose output
# - Use --dry-run to check for updates and report what would happen without
#   downloading or installing anything (also honoured via IS_DRY_RUN=true,
#   which apt-up/pac-up export automatically when run with --dry-run)
# - Designed for apt-up/pac-up hooks or standalone use
#
# This script uses static directory names (GE-Proton-Latest, GE-Proton-Previous)
# with customized compatibilitytool.vdf files so that Steam doesn't require a
# restart to pick up new GE-Proton versions after initial setup.

set -euo pipefail  # Exit on errors, unset vars, and pipe failures

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'  # No color

# GitHub API URL for latest GE-Proton release
GH_API_URL="https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/latest"

# Uncomment to set a default GE_PROTON_TARGET (optional)
# GE_PROTON_TARGET="/custom/path/to/compatibilitytools.d"

# Static directory and display names
LATEST_DIR="GE-Proton-Latest"
PREVIOUS_DIR="GE-Proton-Previous"
LATEST_INTERNAL="GE-Proton-Latest"
PREVIOUS_INTERNAL="GE-Proton-Previous"
LATEST_DISPLAY_PREFIX="Proton GE Latest"
PREVIOUS_DISPLAY_PREFIX="Proton GE Previous"
VERSION_FILE=".ge-proton-version"

# Debug mode flag
DEBUG=0

# Minimum files expected after extraction (configurable via env var)
MIN_FILES=${MIN_FILES:-5}

# Use apt-up's cecho if available, else fallback to printf
if declare -f cecho >/dev/null 2>&1; then
	log() { cecho "$1" "$2"; }
else
	log() { printf "%b%s%b\n" "${2:-$NC}" "$1" "$NC" >&2; }
fi

# Debug logging function
debug_log() {
	if [[ "$DEBUG" -eq 1 ]]; then
		log "DEBUG: $1" "$YELLOW"
	fi
}

# Function to create a secure temp directory
make_secure_temp() {
	if command -v mktemp >/dev/null 2>&1; then
		mktemp -d /tmp/ge-proton-update.XXXXXX
	else
		local base_dir="${TMPDIR:-/tmp}"
		local template="ge-proton-update.XXXXXX"
		local dir
		local rand
		for _ in {1..10}; do
			rand=$(od -An -N4 -tx /dev/urandom | tr -d ' \n')
			dir="$base_dir/${template/XXXXXX/$rand}"
			if mkdir -m 700 "$dir" 2>/dev/null; then
				echo "$dir"
				return 0
			fi
		done
		log "Error: Failed to create secure temp directory" "$RED"
		exit 1
	fi
}

# Function to detect the effective user
get_effective_user() {
	if [[ "$EUID" -eq 0 ]]; then
		if [[ -v SUDO_USER && -n "$SUDO_USER" ]]; then
			echo "$SUDO_USER"
		else
			echo "root"
		fi
	else
		echo "$USER"
	fi
}

# Function to infer the target user from GE_PROTON_TARGET or fall back to effective user
infer_target_user() {
	local target_dir="$1" effective_user="$2"
	local inferred_user

	# If target_dir is unset or empty, fallback to effective user immediately
	if [[ -z "$target_dir" ]]; then
		debug_log "GE_PROTON_TARGET is unset or empty, using effective user: $effective_user"
		echo "$effective_user"
		return 0
	fi

	# Extract user from path like /home/username/...
	if [[ "$target_dir" =~ ^/home/([^/]+)/ ]]; then
		inferred_user="${BASH_REMATCH[1]}"
		if id "$inferred_user" >/dev/null 2>&1; then
			debug_log "Inferred user from GE_PROTON_TARGET: $inferred_user"
			echo "$inferred_user"
			return 0
		else
			log "Warning: Inferred user '$inferred_user' from GE_PROTON_TARGET does not exist, falling back to $effective_user" "$YELLOW"
		fi
	else
		debug_log "GE_PROTON_TARGET ($target_dir) not in /home, using effective user: $effective_user"
	fi

	# Fallback to effective user
	echo "$effective_user"
}

# Function to detect Steam directory or use override
find_steam_dir() {
	local user="$1" home_dir compat_dir

	if [[ "$EUID" -eq 0 && "$user" != "root" ]]; then
		if ! sudo -u "$user" true 2>/dev/null; then
			log "Error: Cannot switch to user $user via sudo" "$RED"
			exit 1
		fi
	fi

	if [[ -v GE_PROTON_TARGET && -n "${GE_PROTON_TARGET}" ]]; then
		if [[ -d "$GE_PROTON_TARGET" || -w "$(dirname "$GE_PROTON_TARGET")" ]]; then
			if [[ "$EUID" -eq 0 && "$user" != "root" ]]; then
				sudo -u "$user" mkdir -p "$GE_PROTON_TARGET" 2>/dev/null || {
					log "Error: Cannot create $GE_PROTON_TARGET as $user" "$RED"
									exit 1
								}
							else
								mkdir -p "$GE_PROTON_TARGET" 2>/dev/null || {
									log "Error: Cannot create $GE_PROTON_TARGET" "$RED"
																	exit 1
																}
			fi
			echo "$GE_PROTON_TARGET"
			return 0
		else
			log "Warning: GE_PROTON_TARGET ($GE_PROTON_TARGET) is invalid or unwritable" "$RED"
		fi
	fi

	home_dir=$(getent passwd "$user" | cut -d: -f6)
	local steam_base_paths=(
	"$home_dir/.steam/steam"              # Most common native Steam
	"$home_dir/.steam"                    # Older native setups
	# Note: Flatpak Steam is intentionally excluded. Upstream GE-Proton tarballs
	# include pressure-vessel, which fails inside Flatpak's existing sandbox.
	# Flatpak users should install GE-Proton via:
	#   flatpak install com.valvesoftware.Steam.CompatibilityTool.Proton-GE
)

for base in "${steam_base_paths[@]}"; do
	compat_dir="$base/compatibilitytools.d"
	if [[ -d "$compat_dir" ]]; then
		echo "$compat_dir"
		return 0
	fi
done

for base in "${steam_base_paths[@]}"; do
	if [[ -d "$base/steamapps" ]]; then
		compat_dir="$base/compatibilitytools.d"
		if [[ "$EUID" -eq 0 && "$user" != "root" ]]; then
			sudo -u "$user" mkdir -p "$compat_dir" 2>/dev/null || {
				log "Error: Cannot create $compat_dir as $user" "$RED"
							exit 1
						}
					else
						mkdir -p "$compat_dir" 2>/dev/null || {
							log "Error: Cannot create $compat_dir" "$RED"
													exit 1
												}
		fi
		echo "$compat_dir"
		return 0
	fi
done

default_base="$home_dir/.steam/steam"
compat_dir="$default_base/compatibilitytools.d"
if [[ "$EUID" -eq 0 && "$user" != "root" ]]; then
	sudo -u "$user" mkdir -p "$compat_dir" 2>/dev/null || {
		log "Error: Cannot create $compat_dir as $user" "$RED"
			exit 1
		}
	else
		mkdir -p "$compat_dir" 2>/dev/null || {
			log "Error: Cannot create $compat_dir" "$RED"
					exit 1
				}
fi
echo "$compat_dir"
}

# Resolve which GE-Proton build to fetch, as an asset-name suffix.
# Upstream publishes x86_64 assets with no suffix (e.g. GE-Proton11-1.tar.gz)
# and aarch64 assets with an "-aarch64" suffix (GE-Proton11-1-aarch64.tar.gz).
#
# Resolution order:
#   1. GE_PROTON_ARCH override, if set (x86_64/amd64 or aarch64/arm64). An
#      unrecognized override value is treated as a user error (returns 1).
#   2. Auto-detected uname -m.
#   3. An unrecognized CPU falls back to x86_64 with a warning rather than
#      bailing — someone running this on an exotic host is most likely using a
#      translation layer (FEX-Emu, box64, qemu-user, ...), which almost always
#      translates x86_64. Set GE_PROTON_ARCH to choose explicitly.
#
# Echoes the suffix (empty for x86_64) on stdout; warnings/errors go to stderr
# via log(). NOTE: called in a command substitution, so it must never 'exit'
# directly — that would only exit the subshell. Returns 1 to signal a hard error.
resolve_arch_suffix() {
	local requested="${GE_PROTON_ARCH:-$(uname -m)}"

	case "$requested" in
		x86_64|amd64)  echo "" ;;
		aarch64|arm64) echo "-aarch64" ;;
		*)
			if [[ -n "${GE_PROTON_ARCH:-}" ]]; then
				log "Error: Unrecognized GE_PROTON_ARCH '$GE_PROTON_ARCH' (expected x86_64 or aarch64)." "$RED"
				return 1
			fi
			log "Warning: Unsupported CPU architecture '$requested'; assuming x86_64." "$YELLOW"
			log "Set GE_PROTON_ARCH=aarch64 (or x86_64) to choose the build explicitly." "$YELLOW"
			echo ""
			;;
	esac
}

# Function to get latest GE-Proton version and URLs
get_latest_release() {
	local compat_dir_param="$1"  # Pass COMPAT_DIR as parameter
	local release_info http_code
	debug_log "Fetching latest release info from GitHub API"
	debug_log "API URL: $GH_API_URL"
	debug_log "Temp dir: $TMP_DIR"

	http_code=$(curl -s -o "$TMP_DIR/release.json" -w "%{http_code}" "$GH_API_URL" 2>/dev/null) || http_code="000"
	debug_log "HTTP response code: $http_code"

	if [[ ! -f "$TMP_DIR/release.json" ]]; then
		log "Error: Failed to create release.json file" "$RED"
		debug_log "Temp directory contents: $(ls -la "$TMP_DIR" 2>&1)"
		exit 1
	fi

	release_info=$(cat "$TMP_DIR/release.json" 2>&1)
	debug_log "JSON file size: $(wc -c < "$TMP_DIR/release.json" 2>/dev/null || echo "unknown")"
	debug_log "First 200 chars of response: ${release_info:0:200}"

	if [[ "$http_code" -eq 403 ]]; then
		log "Error: GitHub API rate limit exceeded" "$RED"
		debug_log "Full API response: $release_info"
		exit 1
	elif [[ "$http_code" -ne 200 ]]; then
		log "Error: GitHub API request failed with HTTP $http_code" "$RED"
		debug_log "Full API response: $release_info"
		exit 1
	fi

	debug_log "Starting JSON parsing"

	# As of GE-Proton11-1, upstream ships both x86_64 and aarch64 builds, so each
	# release now has two .tar.gz and two .sha512sum assets. Select the asset
	# matching this machine's architecture (or GE_PROTON_ARCH) by its exact
	# filename rather than just "ends with .tar.gz", which would (and did) grab
	# both at once.
	local arch_suffix
	if ! arch_suffix=$(resolve_arch_suffix); then
		# Invalid explicit GE_PROTON_ARCH override; message already shown.
		exit 1
	fi
	debug_log "Arch: uname -m=$(uname -m), GE_PROTON_ARCH='${GE_PROTON_ARCH:-<unset>}', suffix '${arch_suffix:-<none>}'"

	local want_tarball want_checksum
	if command -v jq >/dev/null 2>&1; then
		debug_log "Using jq for JSON parsing"
		version=$(echo "$release_info" | jq -r '.tag_name' 2>/dev/null || echo "")
		debug_log "jq version result: $version"

		want_tarball="${version}${arch_suffix}.tar.gz"
		want_checksum="${version}${arch_suffix}.sha512sum"
		debug_log "Matching tarball asset:  $want_tarball"
		debug_log "Matching checksum asset: $want_checksum"

		tarball_url=$(echo "$release_info" | jq -r --arg want "$want_tarball" '.assets[] | select(.name == $want) | .browser_download_url' 2>/dev/null || echo "")
		debug_log "jq tarball_url result: $tarball_url"
		checksum_url=$(echo "$release_info" | jq -r --arg want "$want_checksum" '.assets[] | select(.name == $want) | .browser_download_url' 2>/dev/null || echo "")
		debug_log "jq checksum_url result: $checksum_url"
	else
		debug_log "Using grep/cut for JSON parsing"
		local all_tarball_urls all_checksum_urls
		if printf 'x' | grep -qP 'x' 2>/dev/null; then
			debug_log "Using grep -P (Perl regex)"
			version=$(echo "$release_info" | grep -oP '"tag_name": "\K[^"]+' 2>/dev/null || echo "")
			all_tarball_urls=$(echo "$release_info" | grep -oP '"browser_download_url": "\K[^"]+\.tar\.gz' 2>/dev/null || echo "")
			all_checksum_urls=$(echo "$release_info" | grep -oP '"browser_download_url": "\K[^"]+\.sha512sum' 2>/dev/null || echo "")
		else
			debug_log "Using basic grep"
			version=$(echo "$release_info" | grep -o '"tag_name": "[^"]*"' 2>/dev/null | head -n1 | cut -d'"' -f4 || echo "")
			all_tarball_urls=$(echo "$release_info" | grep -o '"browser_download_url": "[^"]*\.tar\.gz"' 2>/dev/null | cut -d'"' -f4 || echo "")
			all_checksum_urls=$(echo "$release_info" | grep -o '"browser_download_url": "[^"]*\.sha512sum"' 2>/dev/null | cut -d'"' -f4 || echo "")
		fi

		want_tarball="${version}${arch_suffix}.tar.gz"
		want_checksum="${version}${arch_suffix}.sha512sum"
		debug_log "Matching tarball asset:  $want_tarball"
		debug_log "Matching checksum asset: $want_checksum"

		# Pick the URL whose filename exactly matches our architecture's asset.
		tarball_url=$(grep -F -- "/$want_tarball" <<< "$all_tarball_urls" | head -n1 || echo "")
		checksum_url=$(grep -F -- "/$want_checksum" <<< "$all_checksum_urls" | head -n1 || echo "")

		debug_log "grep/cut version result: $version"
		debug_log "grep/cut tarball_url result: $tarball_url"
		debug_log "grep/cut checksum_url result: $checksum_url"
	fi

	if [[ -z "$version" ]]; then
		log "Error: Failed to parse version from GitHub API" "$RED"
		debug_log "Full API response: $release_info"
		exit 1
	fi

	debug_log "Successfully parsed version: $version"
	debug_log "Checking for assets availability"

	# Check if assets are available
	if [[ -z "$tarball_url" || -z "$checksum_url" ]]; then
		log "Warning: Latest release ($version) doesn't have binary assets available yet" "$YELLOW"
		log "This usually happens when a release is just published but assets are still being uploaded" "$YELLOW"
		log "Please try again in a few minutes, or check: https://github.com/GloriousEggroll/proton-ge-custom/releases/latest" "$YELLOW"

		debug_log "Checking if version already installed in: $compat_dir_param"
		# Check if we already have this version installed via state file
		if [[ -n "$compat_dir_param" && -f "$compat_dir_param/$LATEST_DIR/$VERSION_FILE" ]]; then
			local installed_version
			installed_version=$(cat "$compat_dir_param/$LATEST_DIR/$VERSION_FILE" 2>/dev/null || echo "")
			if [[ "$installed_version" == "$version" ]]; then
				log "$version is already installed as $LATEST_DISPLAY_PREFIX, nothing to do" "$GREEN"
				exit 0
			fi
		fi
		log "Assets not available for download yet, exiting" "$RED"
		exit 1
	fi

	log "Latest version: $version" "$NC"
	debug_log "Tarball URL: $tarball_url"
	debug_log "Checksum URL: $checksum_url"
	debug_log "get_latest_release function completed successfully"
}

# Function to download and verify
download_and_verify() {
	local tarball_name checksum_name
	tarball_name=$(basename "$tarball_url")
	checksum_name=$(basename "$checksum_url")

	log "Downloading $tarball_name..." "$NC"
	debug_log "Download location: $TMP_DIR/$tarball_name"

	if command -v wget >/dev/null 2>&1; then
		debug_log "Using wget for download"
		wget -q --show-progress -O "$TMP_DIR/$tarball_name" "$tarball_url" || {
			log "Error: Download failed with wget" "$RED"
					if [[ "$DEBUG" -eq 1 ]]; then
						wget -O "$TMP_DIR/$tarball_name" "$tarball_url"
					fi
					exit 1
				}
				wget -q -O "$TMP_DIR/$checksum_name" "$checksum_url" || {
					log "Error: Checksum download failed with wget" "$RED"
									exit 1
								}
							else
								debug_log "Using curl for download"
								curl -s -L "$tarball_url" -o "$TMP_DIR/$tarball_name" || {
									log "Error: Download failed with curl" "$RED"
																	if [[ "$DEBUG" -eq 1 ]]; then
																		curl -v -L "$tarball_url" -o "$TMP_DIR/$tarball_name"
																	fi
																	exit 1
																}
																curl -s -L "$checksum_url" -o "$TMP_DIR/$checksum_name" || {
																	log "Error: Checksum download failed with curl" "$RED"
																																	exit 1
																																}
	fi

	if [[ ! -s "$TMP_DIR/$tarball_name" ]]; then
		log "Error: Downloaded tarball is empty or not found at $TMP_DIR/$tarball_name" "$RED"
		exit 1
	fi

	if [[ ! -s "$TMP_DIR/$checksum_name" ]]; then
		log "Error: Downloaded checksum file is empty or not found at $TMP_DIR/$checksum_name" "$RED"
		exit 1
	fi

	log "Verifying checksum..." "$NC"
	cd "$TMP_DIR"
	debug_log "Checksum file content: $(cat "$checksum_name")"
	debug_log "Calculated SHA512: $(sha512sum "$tarball_name")"

	if sha512sum -c "$checksum_name" >/dev/null 2>&1; then
		log "Checksum verification passed" "$GREEN"
	else
		log "Error: Checksum verification failed" "$RED"
		debug_log "Expected vs actual:"
		if [[ "$DEBUG" -eq 1 ]]; then
			sha512sum -c "$checksum_name" || true
		fi
		exit 1
	fi

	debug_log "Tarball exists after verification: $(ls -lh "$TMP_DIR/$tarball_name" 2>/dev/null || echo 'Not found')"
	echo "$tarball_name"
}

# Function to read the installed version from a state file
read_installed_version() {
	local dir="$1"
	if [[ -f "$dir/$VERSION_FILE" ]]; then
		cat "$dir/$VERSION_FILE" 2>/dev/null || echo ""
	else
		echo ""
	fi
}

# Function to write a compatibilitytool.vdf with custom names
write_vdf() {
	local target_dir="$1" internal_name="$2" display_name="$3"
	local vdf_path="$target_dir/compatibilitytool.vdf"

	debug_log "Writing VDF: internal=$internal_name display=$display_name path=$vdf_path"

	cat > "$vdf_path" <<VDFEOF
"compatibilitytools"
{
  "compat_tools"
  {
    "$internal_name" // Internal name of this tool
    {
      // Can register this tool with Steam in two ways:
      //
      // - The tool can be placed as a subdirectory in compatibilitytools.d, in which case this
      //   should be '.'
      //
      // - This manifest can be placed directly in compatibilitytools.d, in which case this should
      //   be the relative or absolute path to the tool's dist directory.
      "install_path" "."

      // For this template, we're going to substitute the display_name key in here, e.g.:
      "display_name" "$display_name"

      "from_oslist"  "windows"
      "to_oslist"    "linux"
}
}
}
VDFEOF
}

# Function to install GE-Proton with static naming and version rotation
install_ge_proton() {
	local user="$1" target_dir="$2" tarball_name="$3" version="$4"
	local latest_path="$target_dir/$LATEST_DIR"
	local previous_path="$target_dir/$PREVIOUS_DIR"

	debug_log "Creating target directory: $target_dir"
	mkdir -p "$target_dir" 2>/dev/null || {
		log "Error: Cannot create $target_dir" "$RED"
			exit 1
		}

		local tarball_path="$TMP_DIR/$tarball_name"
		debug_log "Checking tarball before extraction: $tarball_path"
		debug_log "Tarball details: $(ls -lh "$tarball_path" 2>/dev/null || echo 'Not found')"
		if [[ ! -s "$tarball_path" ]]; then
			log "Error: Tarball not found or empty at $tarball_path" "$RED"
			exit 1
		fi

		local tarball_size
		tarball_size=$(stat -c%s "$tarball_path" 2>/dev/null ||
			stat -f%z "$tarball_path" 2>/dev/null ||
			wc -c < "$tarball_path")
					debug_log "Tarball size: $tarball_size bytes"

					if [[ "$tarball_size" -lt 1000000 ]]; then
						log "Warning: Tarball size ($tarball_size bytes) seems unusually small" "$YELLOW"
					fi

					debug_log "Testing tarball integrity"
					tar -tzf "$tarball_path" >/dev/null 2>&1 || {
						log "Error: Tarball integrity check failed" "$RED"
											debug_log "Trying with verbose output: tar -tvzf $tarball_path"
											if [[ "$DEBUG" -eq 1 ]]; then
												tar -tvzf "$tarball_path" || true
											fi
											exit 1
										}

	# --- Determine the tarball's top-level directory up front ---
	# Detect it from the tarball itself rather than assuming it equals the
	# version tag — arch-suffixed builds (e.g. aarch64) use a different internal
	# directory name. Read the full listing (no early-exit pipe) and take the
	# first path component.
	local tar_listing extracted_top
	tar_listing=$(tar -tzf "$tarball_path" 2>/dev/null || true)
	extracted_top="${tar_listing%%/*}"
	if [[ -z "$extracted_top" || "$extracted_top" == "." ]]; then
		extracted_top="$version"
	fi
	debug_log "Tarball top-level directory: $extracted_top"

	# Run filesystem ops as the target user when we're root acting on someone
	# else's Steam dir (empty prefix otherwise). Passing args through an array
	# avoids the shell-quoting/injection hazards of building a wrapper script.
	local run_as=()
	if [[ "$user" != "root" && "$EUID" -eq 0 ]]; then
		run_as=(sudo -u "$user")
	fi

	# --- Extract into a staging dir on the SAME filesystem as the target ---
	# Extracting BEFORE any rotation means a failed or interrupted extraction
	# never destroys the existing Latest/Previous. The final swap is then a
	# same-filesystem rename.
	local staging_dir="$target_dir/.ge-proton-staging.$$"
	debug_log "Staging directory: $staging_dir"
	rm -rf "$staging_dir" 2>/dev/null || true  # clear any stale staging from an interrupted run
	"${run_as[@]}" mkdir -p "$staging_dir" 2>/dev/null || {
		log "Error: Cannot create staging directory $staging_dir" "$RED"
			exit 1
		}

		log "Extracting $version to $LATEST_DIR..." "$NC"
		debug_log "Extract: tar -xzf $tarball_path -C $staging_dir (as $user)"
		local extract_output
		extract_output=$("${run_as[@]}" tar -xzf "$tarball_path" -C "$staging_dir" 2>&1) || {
			log "Error: Extraction failed${user:+ as user $user}" "$RED"
					debug_log "Extraction output: $extract_output"
					rm -rf "$staging_dir" 2>/dev/null || true
					exit 1
				}

				local staged_path="$staging_dir/$extracted_top"
				if [[ ! -d "$staged_path" ]]; then
					log "Error: Expected extracted directory $staged_path not found" "$RED"
					debug_log "Staging contents: $(ls -la "$staging_dir" 2>&1)"
					rm -rf "$staging_dir" 2>/dev/null || true
					exit 1
				fi

				local file_count
				file_count=$(find "$staged_path" -type f | wc -l)
				debug_log "Files extracted: $file_count"
				if [[ "$file_count" -lt "$MIN_FILES" ]]; then
					log "Warning: Extraction produced fewer files than expected ($file_count < $MIN_FILES)" "$YELLOW"
				fi

	# --- Now that a good build is staged, rotate Latest → Previous ---
	local current_latest_version
	current_latest_version=$(read_installed_version "$latest_path")
	debug_log "Current Latest version: ${current_latest_version:-none}"

	if [[ -d "$latest_path" && -n "$current_latest_version" ]]; then
		log "Rotating $LATEST_DIR ($current_latest_version) → $PREVIOUS_DIR..." "$NC"

		if [[ -d "$previous_path" ]]; then
			local previous_version
			previous_version=$(read_installed_version "$previous_path")
			debug_log "Removing existing Previous (${previous_version:-unknown})"
			rm -rf "$previous_path" 2>/dev/null || {
				log "Warning: Failed to remove $previous_path" "$YELLOW"
			}
		fi

		mv "$latest_path" "$previous_path" 2>/dev/null || {
			log "Error: Failed to rotate $LATEST_DIR → $PREVIOUS_DIR" "$RED"
					rm -rf "$staging_dir" 2>/dev/null || true
					exit 1
				}

				write_vdf "$previous_path" "$PREVIOUS_INTERNAL" "$PREVIOUS_DISPLAY_PREFIX"
				if [[ "$EUID" -eq 0 && "$user" != "root" ]]; then
					chown "$user:$user" "$previous_path/compatibilitytool.vdf" 2>/dev/null || true
				fi

				log "Previous version: $current_latest_version" "$GREEN"
			else
				# No usable Latest to rotate; clear any stale/partial Latest so the swap
				# below creates a clean directory instead of nesting inside it.
				rm -rf "$latest_path" 2>/dev/null || true
	fi

	# --- Swap the staged build into place (same-filesystem rename) ---
	debug_log "Moving $staged_path → $latest_path"
	mv "$staged_path" "$latest_path" 2>/dev/null || {
		log "Error: Failed to move staged build into $latest_path" "$RED"
			rm -rf "$staging_dir" 2>/dev/null || true
			exit 1
		}
		rm -rf "$staging_dir" 2>/dev/null || true

	# Fix ownership of the new Latest if running as root for another user
	if [[ "$EUID" -eq 0 && "$user" != "root" ]]; then
		chown -R "$user:$user" "$latest_path" 2>/dev/null || {
			log "Warning: Failed to set ownership of $latest_path to $user" "$YELLOW"
		}
	fi

	# --- Write VDF and state file ---
	write_vdf "$latest_path" "$LATEST_INTERNAL" "$LATEST_DISPLAY_PREFIX"
	debug_log "Wrote VDF: internal=$LATEST_INTERNAL display=$LATEST_DISPLAY_PREFIX"

	echo "$version" > "$latest_path/$VERSION_FILE"
	debug_log "Wrote version state file: $version"

	if [[ "$EUID" -eq 0 && "$user" != "root" ]]; then
		chown "$user:$user" "$latest_path/compatibilitytool.vdf" "$latest_path/$VERSION_FILE" 2>/dev/null || true
	fi

	log "$version installed as '$LATEST_DISPLAY_PREFIX'!" "$GREEN"

	if [[ -z "$current_latest_version" ]]; then
		log "==> Note: Steam requires a restart for the initial setup of $LATEST_DISPLAY_PREFIX." "$GREEN"
		log "In Steam: Steam > Settings > Compatibility > Set 'Default compatibility tool' to '$LATEST_DISPLAY_PREFIX'." "$GREEN"
		log "Future updates will be picked up automatically without restarting Steam." "$GREEN"
	else
		log "==> Updated in-place. No Steam restart required." "$GREEN"
	fi

	return 0
}

# Function to clean up legacy versioned GE-Proton directories
cleanup_legacy_versions() {
	local user="$1" target_dir="$2"
	local found_legacy=0

	debug_log "Scanning for legacy versioned GE-Proton directories..."

	while IFS= read -r dir; do
		[[ -z "$dir" ]] && continue
		local dirname
		dirname=$(basename "$dir")

		# Skip our managed static directories
		if [[ "$dirname" == "$LATEST_DIR" || "$dirname" == "$PREVIOUS_DIR" ]]; then
			continue
		fi

		# Match legacy versioned directories (e.g., GE-Proton10-30, GE-Proton9-27)
		if [[ "$dirname" =~ ^GE-Proton[0-9] ]]; then
			if [[ "$found_legacy" -eq 0 ]]; then
				log "Cleaning up legacy GE-Proton directories..." "$NC"
				found_legacy=1
			fi
			log "Removing legacy $dirname..." "$NC"
			if [[ "$user" != "root" && "$EUID" -eq 0 ]]; then
				sudo -u "$user" rm -rf "$dir" 2>/dev/null || {
					log "Warning: Failed to remove $dir" "$YELLOW"
				}
			else
				rm -rf "$dir" 2>/dev/null || {
					log "Warning: Failed to remove $dir" "$YELLOW"
				}
			fi
		fi
	done < <(find "$target_dir" -maxdepth 1 -type d -name 'GE-Proton*' 2>/dev/null)

	if [[ "$found_legacy" -eq 1 ]]; then
		log "Legacy cleanup complete." "$NC"
	else
		debug_log "No legacy versioned directories found."
	fi
}

# Check for flags
FORCE_ROOT=0
for arg in "$@"; do
	if [[ "$arg" == "--force-root" ]]; then
		FORCE_ROOT=1
	elif [[ "$arg" == "--debug" ]]; then
		DEBUG=1
	elif [[ "$arg" == "--dry-run" ]]; then
		IS_DRY_RUN=true
	fi
done

# Print system info in debug mode
if [[ "$DEBUG" -eq 1 ]]; then
	debug_log "System info: $(uname -a)"
	debug_log "Current user: $(whoami)"
	debug_log "EUID: $EUID"
	if [[ -v SUDO_USER ]]; then
		debug_log "SUDO_USER: $SUDO_USER"
	fi
fi

# Main execution
log "Checking for GE-Proton updates..." "$NC"

EFFECTIVE_USER=$(get_effective_user)
debug_log "Effective user: $EFFECTIVE_USER"

# Infer the target user, passing GE_PROTON_TARGET only if set, otherwise an empty string
TARGET_USER=$(infer_target_user "${GE_PROTON_TARGET:-}" "$EFFECTIVE_USER")
debug_log "Target user for installation: $TARGET_USER"

TARGET_SET=0
if [[ -v GE_PROTON_TARGET && -n "${GE_PROTON_TARGET}" ]]; then
	if [[ -d "$GE_PROTON_TARGET" || -w "$(dirname "$GE_PROTON_TARGET")" ]]; then
		COMPAT_DIR="$GE_PROTON_TARGET"
		TARGET_SET=1
		log "Using overridden Steam directory: $COMPAT_DIR" "$NC"
	else
		# If running as root, try to fix permissions or error out
		if [[ "$EUID" -eq 0 ]]; then
			if [[ "$TARGET_USER" != "root" ]]; then
				sudo -u "$TARGET_USER" mkdir -p "$GE_PROTON_TARGET" 2>/dev/null || {
					log "Error: GE_PROTON_TARGET ($GE_PROTON_TARGET) is invalid or unwritable even as $TARGET_USER" "$RED"
									exit 1
								}
								COMPAT_DIR="$GE_PROTON_TARGET"
								TARGET_SET=1
								log "Created and using overridden Steam directory: $COMPAT_DIR" "$NC"
							else
								log "Error: GE_PROTON_TARGET ($GE_PROTON_TARGET) is invalid or unwritable for root" "$RED"
								exit 1
			fi
		else
			log "Error: GE_PROTON_TARGET ($GE_PROTON_TARGET) is invalid or unwritable" "$RED"
			exit 1
		fi
	fi
fi

if [[ "$TARGET_SET" -eq 0 && "$EFFECTIVE_USER" == "root" && "$EUID" -eq 0 && ! -v SUDO_USER ]]; then
	if [[ "$FORCE_ROOT" -eq 1 ]]; then
		log "Installing to root's Steam dir with --force-root" "$NC"
	else
		log "Skipping GE-Proton update: Running as root without sudo user, --force-root, or valid GE_PROTON_TARGET" "$RED"
		exit 0
	fi
fi

if [[ "$TARGET_SET" -eq 0 ]]; then
	COMPAT_DIR=$(find_steam_dir "$TARGET_USER")
	log "Using Steam directory: $COMPAT_DIR" "$NC"
	debug_log "Target directory access check: $(ls -la "$COMPAT_DIR" 2>&1 || echo "Cannot access")"
fi

# Ensure the target directory is owned by the target user if running as root
if [[ "$EUID" -eq 0 && "$TARGET_USER" != "root" ]]; then
	chown "$TARGET_USER:$TARGET_USER" "$COMPAT_DIR" 2>/dev/null || {
		log "Warning: Failed to set ownership of $COMPAT_DIR to $TARGET_USER" "$RED"
	}
fi

TMP_DIR=$(make_secure_temp)
debug_log "Using temp directory: $TMP_DIR"

# Install cleanup trap right after creation so the temp dir can't leak if any
# of the setup below fails.
trap 'rm -rf "$TMP_DIR" && debug_log "Cleanup: Removed temp directory" || log "Warning: Failed to clean up $TMP_DIR" "$RED"' EXIT

if [[ "$EUID" -eq 0 && "$TARGET_USER" != "root" ]]; then
	debug_log "Setting permissions on temp directory for $TARGET_USER"
	chown "$TARGET_USER:$TARGET_USER" "$TMP_DIR" || {
		log "Warning: Failed to set ownership of temp directory to $TARGET_USER" "$RED"
			debug_log "Current temp dir permissions: $(ls -la "$TMP_DIR")"
		}
		chmod 700 "$TMP_DIR" || {
			log "Warning: Failed to set permissions on temp directory" "$RED"
		}
fi

get_latest_release "$COMPAT_DIR"

# Check installed version via state file instead of directory name
INSTALLED_VERSION=$(read_installed_version "$COMPAT_DIR/$LATEST_DIR")
debug_log "Installed version (from state file): ${INSTALLED_VERSION:-none}"

if [[ "$INSTALLED_VERSION" == "$version" ]]; then
	log "$version already installed as $LATEST_DISPLAY_PREFIX" "$NC"
	INSTALL_NEEDED=0
else
	INSTALL_NEEDED=1
	if [[ -n "$INSTALLED_VERSION" ]]; then
		debug_log "Version change detected: $INSTALLED_VERSION → $version"
	else
		debug_log "No existing installation found, fresh install needed"
	fi
fi

if [[ "$INSTALL_NEEDED" -eq 1 ]]; then
	if [[ "${IS_DRY_RUN:-false}" == "true" ]]; then
		if [[ -n "$INSTALLED_VERSION" ]]; then
			log "[DRY-RUN] Would update GE-Proton: $INSTALLED_VERSION → $version" "$NC"
		else
			log "[DRY-RUN] Would install GE-Proton $version (first install)" "$NC"
		fi
	else
		tarball_name=$(download_and_verify)
		debug_log "Tarball name returned: $tarball_name"
		debug_log "Full tarball path: $TMP_DIR/$tarball_name"
		debug_log "Tarball check before install: $(ls -lh "$TMP_DIR/$tarball_name" 2>/dev/null || echo 'Not found')"
		install_ge_proton "$TARGET_USER" "$COMPAT_DIR" "$tarball_name" "$version"
	fi
else
	log "No update needed." "$NC"
fi

# Clean up any legacy versioned directories from older script behavior
if [[ "${IS_DRY_RUN:-false}" == "true" ]]; then
	log "[DRY-RUN] Would clean up legacy GE-Proton directories" "$NC"
else
	cleanup_legacy_versions "$TARGET_USER" "$COMPAT_DIR"
fi

log "Done!" "$NC"

exit 0
